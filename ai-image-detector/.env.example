# ── PRIMARY: Hive V3 — 94% accuracy, 100 req/day free ──────────
# Sign up at: https://portal.thehive.ai/signup
# Returns: AI score + source generator (DALL-E, Midjourney, SD, Flux...)
VITE_HIVE_API_KEY=your_v3_api_key_here

# ── FALLBACK: Hugging Face (used if Hive key is not set) ────────
# Sign up at: https://huggingface.co → Settings → Access Tokens
VITE_HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxx

# ── ERROR TRACKING: Sentry (optional) ─────────────────────────
# Sign up at: https://sentry.io → Create Project → React
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ── WEBGL FALLBACK: Cloudflare Workers AI (optional) ───────────
# Only needed when user's browser doesn't support WebGL
VITE_CF_WORKER_URL=https://your-worker.your-subdomain.workers.dev
